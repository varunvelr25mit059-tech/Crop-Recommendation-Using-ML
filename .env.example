DATABASE_URL=postgresql://user:password@localhost:5432/smartcrop

# JWT Security
JWT_SECRET=your-super-secret-jwt-key-2026-agritech
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Server settings
